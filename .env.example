# ════════════════════════════════════════════════════════════
#  MailGuardianX — variables non-secrètes
#
#  Les secrets sensibles (mots de passe, tokens, client_secret Azure)
#  ne sont PAS ici — ils vont dans ./secrets/*.txt (Docker Secrets).
#
#  Voir docker-compose.yml + ./secrets/README.md pour la liste complète.
# ════════════════════════════════════════════════════════════

# ── Orchestrator ──
ORCHESTRATOR_PORT=8000
LOG_LEVEL=INFO
DEBUG=false
ALLOWED_ORIGINS=["https://dashboard.mailguardianx.local"]

# ── Scheduler Graph API ──
# Mettre à true uniquement quand les secrets Azure sont configurés
SCHEDULE_ENABLED=false
SCHEDULE_INTERVAL_MINUTES=15
SCHEDULE_EMAILS_PER_USER=25
SCHEDULE_MAX_USERS=500
SCHEDULE_DIFFERENTIAL=true

# ── Détection ──
CLAMAV_ENABLED=true
CLAMAV_TIMEOUT=30
YARA_ENABLED=true
YARA_TIMEOUT=60

# ── Scoring ──
SCORE_THRESHOLD_ALLOW=0.3
SCORE_THRESHOLD_SUSPECT=0.6
SCORE_THRESHOLD_BLOCK=0.8

# ── CAPE Sandbox ──
CAPE_TIMEOUT=300
CAPE_POLL_INTERVAL=10
CAPE_MAX_FILE_SIZE=52428800

# ── MISP ──
MISP_VERIFY_SSL=false
MISP_BASEURL=https://misp.mailguardianx.local

# ── Monitoring ──
GRAFANA_USER=admin

# ── Celery ──
CELERY_TASK_TIME_LIMIT=900
CELERY_TASK_SOFT_TIME_LIMIT=600
